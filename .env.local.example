# MongoDB Connection
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@cluster-name.mongodb.net/lokswami?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster-name.mongodb.net/lokswami?retryWrites=true&w=majority

# DigitalOcean Spaces media storage (required for uploads in production)
# Create a Standard Spaces bucket, enable CDN, then create a limited access key
# with Read/Write/Delete permission for that bucket.
DIGITALOCEAN_SPACES_ACCESS_KEY=
DIGITALOCEAN_SPACES_SECRET_KEY=
DIGITALOCEAN_SPACES_BUCKET=
DIGITALOCEAN_SPACES_REGION=sgp1
DIGITALOCEAN_SPACES_CDN_BASE_URL=https://your-bucket.sgp1.cdn.digitaloceanspaces.com

# Auth Secret for JWT signing (required, minimum 32 chars)
# Generate one: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-value

# Admin Credentials (for initial login)
# Username for admin login
ADMIN_USERNAME=zaid@lokswami

# Password hash (bcrypt hashed password)
# To generate: npm run hash-password
# Example only (bcrypt hash of "password"): $2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcg7b3XeKeUxWdeS86E36jbMFm2
ADMIN_PASSWORD_HASH=$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcg7b3XeKeUxWdeS86E36jbMFm2

# Optional: comma-separated extra hosts for next/image remote loading
# Keep this strict (no wildcards). Example: cdn.example.com,media.example.in
NEXT_IMAGE_ALLOWED_HOSTS=

# Reader Google Auth (optional, required for "Continue with Google")
# Used by NextAuth Google admin login and the existing reader Google flow.
# Get from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Get the matching OAuth client secret from the same Google Cloud Console credential.
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Use the same OAuth client ID for the legacy client-side Google flow if you still need it.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Generate a long random secret used by NextAuth.js for session security.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep this value the same anywhere you need the same auth/session state to be readable.
NEXTAUTH_SECRET=replace-with-a-long-random-secret-for-nextauth
# Base URL of this app.
# Local example: http://localhost:3000
# Production example (Hostinger): https://lokswami.com
NEXTAUTH_URL=http://localhost:3000
# Public site URL used for metadata, sitemaps, and share links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional Google Tag Manager container ID.
# Example: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# Google Cloud Console values for this OAuth client:
# Authorized JavaScript origins:
# - http://localhost:3000
# - https://lokswami.com
# Authorized redirect URIs:
# - http://localhost:3000/api/auth/callback/google
# - https://lokswami.com/api/auth/callback/google

# Paid external AI APIs
# OpenAI and Gemini API keys are intentionally not configured.
# Use ChatGPT Plus manually in the browser, then paste approved text into the CMS.

# OCR for e-paper hotspot auto-detection
# Default is local/manual OCR only. Keep remote fallback off to avoid paid API usage.
# Preferred OCR language code (3 letters): hin, eng, etc.
OCR_SPACE_LANGUAGE=hin

# Custom OCR endpoint (optional)
# If set, /api/admin/epapers/assist uses this endpoint instead of OCR.Space.
# Request body sent:
# { "image": "<data-url-or-http-url>", "mode": "base64|url", "language": "hin" }
# Response format (choose one):
# 1) { "hotspots": [ { "x":0, "y":0, "width":0, "height":0, "title":"", "text":"", "page":1 } ] }
# 2) { "lines": [ { "text":"...", "left":0, "top":0, "right":100, "bottom":120 } ] }
OCR_CUSTOM_API_URL=
# Optional bearer token for custom OCR endpoint.
OCR_CUSTOM_API_KEY=

# Optional: force browser local OCR only (skip /api/admin/epapers/assist calls).
# Set to true to avoid OCR provider errors/logs completely.
NEXT_PUBLIC_EPAPER_LOCAL_OCR_ONLY=true

# Optional: allow remote OCR fallback when local browser OCR fails.
# Keep false if you want a fully free/local-only setup.
NEXT_PUBLIC_EPAPER_REMOTE_OCR_FALLBACK=false

# Optional writable uploads base dir for e-paper files.
# Use an absolute server path if your host restricts writes inside app root.
EPAPER_STORAGE_UPLOADS_BASE_DIR=storage/uploads
# Optional: force proxy-backed uploads instead of writing runtime files into public/uploads.
# Recommended for versioned/immutable production deploys like Hostinger GitHub releases.
# EPAPER_FORCE_STORAGE=1
