# MongoDB
MONGODB_URI=mongodb+srv://your_username:your_password@cluster-name.mongodb.net/lokswami?retryWrites=true&w=majority

# NextAuth + Google OAuth
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
LEADERSHIP_REPORT_FROM_EMAIL=
LEADERSHIP_REPORT_CRON_SECRET=
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
ADMIN_EMAILS=admin@example.com

# DigitalOcean Spaces media storage
# Create a Standard Spaces bucket, enable CDN, then create a limited access key
# with Read/Write/Delete permission for that bucket.
DIGITALOCEAN_SPACES_ACCESS_KEY=
DIGITALOCEAN_SPACES_SECRET_KEY=
DIGITALOCEAN_SPACES_BUCKET=
DIGITALOCEAN_SPACES_REGION=sgp1
DIGITALOCEAN_SPACES_CDN_BASE_URL=https://your-bucket.sgp1.cdn.digitaloceanspaces.com

# Optional legacy secret aliases still supported by middleware/auth helpers
JWT_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret

# Optional OCR integrations
# Default is local/manual OCR only. Do not set paid AI API keys here.
OCR_SPACE_LANGUAGE=hin
OCR_CUSTOM_API_URL=
OCR_CUSTOM_API_KEY=
NEXT_PUBLIC_EPAPER_LOCAL_OCR_ONLY=true
NEXT_PUBLIC_EPAPER_REMOTE_OCR_FALLBACK=false

# Optional extra remote image hosts for next/image
NEXT_IMAGE_ALLOWED_HOSTS=

# Optional writable uploads base dir for e-paper assets
EPAPER_STORAGE_UPLOADS_BASE_DIR=storage/uploads

# Optional AI avatar image (external URL or absolute path). Example:
# NEXT_PUBLIC_AI_AVATAR_URL=https://cdn.example.com/lokswami-ai-female.png
# NEXT_PUBLIC_AI_AVATAR_URL=/ai/female-ai-bot.png
NEXT_PUBLIC_AI_AVATAR_URL=

